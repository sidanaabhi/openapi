# Copy to .env and fill in real values. Never commit .env to source control.

# PostgreSQL password (default: localdev — change for any shared/cloud env)
POSTGRES_PASSWORD=localdev

# Microsoft Entra ID (Azure AD) — required for auth
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_CLIENT_SECRET=

# 32-byte hex key for encrypting subscription key ciphertexts
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
